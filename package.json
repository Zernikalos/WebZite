    "fumadocs-ui": "16.7.10",
    "lucide-react": "1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "shiki": "4.0.2",
    "tailwind-merge": "3.5.0",
    "tinyglobby": "0.2.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
